  "sequencing": {
    "phase_0": {
      "label": "Foundation gate",
      "agents": ["agent_1"],
      "must_complete_before": ["agent_2", "agent_3", "agent_4", "agent_5", "agent_6"]
    },
    "phase_1": {
      "label": "Infrastructure parallel work",
      "agents": ["agent_2", "agent_3", "agent_4"],
      "parallel": true,
      "notes": "All three can start immediately after Agent 1 completes. Agent 3 ZipAccess work is unblocked; parser internals await sample data."
    },
    "phase_2": {
      "label": "Dedupe + diagnostics start",
      "agents": ["agent_5", "agent_6"],
      "parallel": true,
      "notes": "Agent 5 starts after Agent 4 PhotosAccess is ready. Agent 6 diagnostics infra can start in parallel; success/settings wiring overlaps with Phase 1 tail."
    },
    "phase_3": {
      "label": "Integration and hardening",
      "agents": ["agent_6"],
      "notes": "Final pass: success screen wiring, resume banner, cleanup, 20 GB hardening. Requires all engines substantially complete."
    }
  },
  "parallel_groups": [
    {
      "group": "Phase 1 — fully parallel",
      "agents": ["agent_2", "agent_3", "agent_4"],
      "reason": "Non-overlapping package ownership. Agent 2 owns Persistence stores. Agent 3 owns ZipAccess + ImportEngine/Parsing. Agent 4 owns PhotosAccess + ImportEngine/Execution."
    },
    {
      "group": "Phase 2 — partially parallel",
      "agents": ["agent_5", "agent_6"],
      "reason": "Agent 5 depends on Agent 4 PhotosAccess but can scaffold DedupeEngine classification logic independently. Agent 6 can start Diagnostics infra independently."
    }
  ],
  "dependency_edges": [
    {
      "from": "agent_1",
      "to": "agent_2",
      "type": "hard",
      "reason": "Shell must exist before persistence can be implemented"
    },
    {
      "from": "agent_1",
      "to": "agent_3",
      "type": "hard",
      "reason": "Shell must exist before ZipAccess/parser work"
    },
    {
      "from": "agent_1",
      "to": "agent_4",
      "type": "hard",
      "reason": "Shell must exist before PhotosAccess/import work"
    },
    {
      "from": "agent_2",
      "to": "agent_3",
      "type": "soft",
      "reason": "Agent 3 needs working stores to persist parsed records. Can build ZipAccess while waiting."
    },
    {
      "from": "agent_2",
      "to": "agent_4",
      "type": "soft",
      "reason": "Agent 4 needs working stores for checkpointing. Can build PhotosAccess while waiting."
    },
    {
      "from": "agent_4",
      "to": "agent_5",
      "type": "hard",
      "reason": "Agent 5 needs PhotosLibraryQuerying and PhotoLibraryDeletionService implementations from Agent 4"
    },
    {
      "from": "agent_2",
      "to": "agent_5",
      "type": "soft",
      "reason": "Agent 5 needs working duplicate candidate store"
    },
    {
      "from": "agent_3",
      "to": "agent_5",
      "type": "soft",
      "reason": "Agent 5 needs ImportAsset rows with content hashes for comparison"
    },
    {
      "from": "agent_2",
      "to": "agent_6",
      "type": "soft",
      "reason": "Agent 6 needs persistence for session/failure queries"
    },
    {
      "from": "agent_4",
      "to": "agent_6",
      "type": "soft",
      "reason": "Success screen needs real import execution data"
    },
    {
      "from": "agent_5",
      "to": "agent_6",
      "type": "soft",
      "reason": "Success screen needs dedupe results for summary"
