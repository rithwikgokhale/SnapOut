  "merge_risk_areas": [
    {
      "area": "App/DependencyContainer.swift",
      "risk": "high",
      "reason": "Every agent registers real implementations here",
      "mitigation": "Agents add registrations in clearly marked sections. Principal engineer reviews all DI changes."
    },
    {
      "area": "ImportEngine/Coordinator/ImportCoordinator.swift",
      "risk": "high",
      "reason": "Agents 3 and 4 both implement phases of the coordinator",
      "mitigation": "Recommend splitting into ScanCoordinator (Agent 3) and ExecutionCoordinator (Agent 4) during shell. Top-level ImportCoordinator delegates."
    },
    {
      "area": "App/RootNavigation.swift",
      "risk": "medium",
      "reason": "Multiple agents could modify navigation structure",
      "mitigation": "Shell wires all routes. Agents only change their owned feature package internals."
    },
    {
      "area": "AppCore protocol files",
      "risk": "medium",
      "reason": "Agents may need method additions",
      "mitigation": "Freeze after shell. Changes require principal engineer approval."
    },
    {
      "area": "DomainModels model files",
      "risk": "medium",
      "reason": "Agents may discover missing fields",
      "mitigation": "Freeze after shell. Additions require principal engineer approval and a migration."
    }
  ],
  "review_order": [
    {
      "order": 1,
      "agent": "agent_1",
      "gate": true,
      "check": "All packages exist, dependency graph correct, protocols match brief, design system matches spec, database schema matches brief, all screens compile"
    },
    {
      "order": 2,
      "agent": "agent_2",
      "gate": false,
      "check": "All stores implement full protocol surface, queries correct, batch operations work, mock stores exist"
    },
    {
      "order": 3,
      "agent": "agent_3",
      "gate": false,
      "check": "Framework isolation respected (ZIPFoundation only in ZipAccess), protocols consumed correctly, DI registrations correct, feature screens use DesignSystem"
    },
    {
      "order": 3,
      "agent": "agent_4",
      "gate": false,
      "check": "Framework isolation respected (PhotoKit only in PhotosAccess), protocols consumed correctly, DI registrations correct, feature screens use DesignSystem"
    },
    {
      "order": 4,
      "agent": "agent_5",
      "gate": false,
      "check": "Three-phase duplicate flow correctly separated, delete review separate from keep/skip, confidence thresholds flagged for human review, library_asset_cache treated as stale-able cache"
    },
    {
      "order": 5,
      "agent": "agent_6",
      "gate": false,
      "check": "Success screen uses real data, diagnostics redacted, cleanup works, resume banner works, no scope expansion"
    }
  ],
  "blocking_items": [
    {
      "item": "Agent 1 shell completion",
      "blocks": "All other agents",
      "type": "hard_gate"
    },
    {
      "item": "Sample Snapchat export data",
      "blocks": "Agent 3 parser internals and parser tests",
      "type": "external_blocker"
    },
    {
      "item": "Agent 4 PhotosAccess implementation",
      "blocks": "Agent 5 real candidate narrowing and deletion review",
      "type": "inter_agent_dependency"
    },
    {
      "item": "ImportCoordinator split decision",
      "blocks": "Clean parallel work between Agent 3 and Agent 4 on ImportEngine",
      "type": "architectural_decision",
      "recommendation": "Split into ScanCoordinator and ExecutionCoordinator during shell"
    }
  ]
